CLOUDVAULT_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CLOUDVAULT_STORAGE_LIMIT=1073741824
CLOUDVAULT_SECRET_KEY=dev-only-secret-change-in-prod

# Firebase Auth (set true to enable)
CLOUDVAULT_USE_FIREBASE_AUTH=false
# Absolute path to Firebase service account JSON file
CLOUDVAULT_FIREBASE_CREDENTIALS_JSON=C:/path/to/firebase-service-account.json

# Cloudflare R2 (set true to enable)
CLOUDVAULT_USE_R2=false
CLOUDVAULT_R2_ACCOUNT_ID=
CLOUDVAULT_R2_ACCESS_KEY_ID=
CLOUDVAULT_R2_SECRET_ACCESS_KEY=
CLOUDVAULT_R2_BUCKET=
CLOUDVAULT_R2_REGION=auto
# Optional override (normally auto-built from account id)
CLOUDVAULT_R2_ENDPOINT=
