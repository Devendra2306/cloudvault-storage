# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL="file:./prisma/dev.db"

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=

# Resend (email) — optional until you finish setup below
RESEND_API_KEY=
EMAIL_FROM=CloudVault <onboarding@resend.dev>
# After Resend is working, enable verification for uploads:
# REQUIRE_EMAIL_VERIFICATION=true
# SKIP_EMAIL_VERIFICATION=true
